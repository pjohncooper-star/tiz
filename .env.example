# Copy to .env and fill in secrets:  cp .env.example .env

# Database (Neon pooled connection string)
DATABASE_URL=

# Auth (local dev)
AUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Strava (optional for local)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_WEBHOOK_VERIFY_TOKEN=

# Inngest (local dev)
INNGEST_DEV=1

# --- Plan feature flags (must be exactly "true" to enable) ---

# Unlocks /plan and season APIs
FEATURE_PLAN_BUILDER=true

# New volume-first single-page season planner at /plan
FEATURE_SIMPLE_SEASON_PLANNER=true

# Legacy wizard + zone dashboard (optional; omit or set false for simple-only)
# FEATURE_ADVANCED_SEASON_PLANNER=true

# Calendar, workout library, session editor (optional)
FEATURE_PLANNING_CALENDAR=true
